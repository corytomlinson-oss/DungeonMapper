[Unit]
Description=Dungeon Mapper
After=network.target

[Service]
Type=simple
User=cory
WorkingDirectory=/home/cory/HomeHub/DungeonMapper
ExecStart=/home/cory/HomeHub/DungeonMapper/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8085
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
